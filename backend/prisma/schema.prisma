generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  LAB_TECH
  PHARMACIST
  NURSE
  PATIENT
}

enum DepartmentState {
  AWAITING_TRIAGE
  AWAITING_DOCTOR
  AWAITING_LAB
  AWAITING_DOCTOR_REVIEW
  AWAITING_PHARMACY
  DISCHARGED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  patientFlow          PatientFlow?       @relation("PatientFlowUser")
  doctorConsultations  ConsultationNote[] @relation("DoctorConsultations")
  patientConsultations ConsultationNote[] @relation("PatientConsultations")
  dispensedPrescriptions Prescription[]   @relation("PharmacistPrescriptions")
  conductedTests       LabTest[]          @relation("LabTechTests")
  patientLabTests      LabTest[]          @relation("PatientLabTests")
  patientPrescriptions Prescription[]     @relation("PatientPrescriptions")
}

model PatientFlow {
  id               String          @id @default(uuid())
  patient          User            @relation("PatientFlowUser", fields: [patientId], references: [id], onDelete: Cascade)
  patientId        String          @unique
  currentState     DepartmentState @default(AWAITING_TRIAGE)
  assignedDoctorId String?
  assignedLabId    String?
  assignedPharmId  String?
  queueEnteredAt   DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ConsultationNote {
  id            String   @id @default(uuid())
  patient       User     @relation("PatientConsultations", fields: [patientId], references: [id], onDelete: Cascade)
  patientId     String
  doctor        User     @relation("DoctorConsultations", fields: [doctorId], references: [id])
  doctorId      String
  notes         String   // Highly sensitive PII!
  isImmutable   Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model LabTest {
  id            String   @id @default(uuid())
  patient       User     @relation("PatientLabTests", fields: [patientId], references: [id], onDelete: Cascade)
  patientId     String
  testName      String
  status        String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  resultData    String?  // Highly sensitive PII!
  labTech       User?    @relation("LabTechTests", fields: [labTechId], references: [id])
  labTechId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Prescription {
  id            String   @id @default(uuid())
  patient       User     @relation("PatientPrescriptions", fields: [patientId], references: [id], onDelete: Cascade)
  patientId     String
  drugName      String
  dosage        String
  status        String   @default("PENDING") // PENDING, DISPENSED
  pharmacist    User?    @relation("PharmacistPrescriptions", fields: [pharmacistId], references: [id])
  pharmacistId  String?
  createdAt     DateTime @default(now())
  dispensedAt   DateTime?
}

model Inventory {
  id        String   @id @default(uuid())
  drugName  String   @unique
  stock     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Drug {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LabTestTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  category    String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
